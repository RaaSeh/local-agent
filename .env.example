# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Lead research sources (required for daily pwasher run)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Optional BC Registry enrichment
BC_REGISTRY_API_URL=https://your-bc-registry-search-endpoint
BC_REGISTRY_API_KEY=your_bc_registry_api_key
LEAD_RESEARCH_MAX_QUERIES=12

# Sanity headless CMS (multi-tenant Phase 1, draft-only)
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_API_TOKEN=your_sanity_write_token
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Anthropic / Claude
ANTHROPIC_API_KEY=your_key_here

# Pick a Claude model you have access to (adjust later)
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4.1-mini

# Perplexity
PERPLEXITY_API_KEY=your_perplexity_key
PERPLEXITY_MODEL=sonar-pro

# Deterministic orchestrator settings
PROMPTS_DIR=prompts
RUNS_DIR=runs
RUN_BUDGET_CAP_USD=3.0
ESCALATION_CONFIDENCE_THRESHOLD=0.7

# Google Chat bridge
GOOGLE_CHAT_ENDPOINT_URL=https://razedevstudios.com.gigachad/google-chat/events
GOOGLE_CHAT_VERIFICATION_TOKEN=set_a_long_random_secret
CHAT_ALLOWED_USERS=you@razedevstudios.com,partner@razedevstudios.com
CHAT_MAX_RESPONSE_CHARS=3500

# Telegram local bot (recommended for local-first field workflow)
TELEGRAM_BOT_TOKEN=123456789:replace_with_botfather_token
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_MAX_RESPONSE_CHARS=3500
MEDIA_SAVE_DIR=state/media/
WORKSPACE_ROOT=.

# External R&D project directory.
# When set, both the business-plan pipeline and the admin workspace brief will
# read STATUS.md, README.md, and the directory tree from this folder before
# any LLM call, so agents reason over actual code — not invented placeholders.
# Example:
# EXTERNAL_PROJECT_DIR=C:\Users\platt\Desktop\AgenticCAD
EXTERNAL_PROJECT_DIR=